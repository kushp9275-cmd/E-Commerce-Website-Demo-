# Flask Settings
SECRET_KEY=your_super_secret_key_here

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# SMTP Email Configuration (For real registration confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Twilio SMS Configuration (For real password reset SMS OTPs)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Admin Security Code (For admin registration validation)
ADMIN_SECURITY_CODE=ADMIN123
